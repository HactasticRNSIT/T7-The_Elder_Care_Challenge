<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CareNest AI — Predictive Elder Care</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800;900&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --teal: #2DC4B2;
  --teal-light: #E0F7F5;
  --teal-mid: #4DD9C8;
  --cyan: #38BDF8;
  --blue: #3B82F6;
  --blue-soft: #DBEAFE;
  --sky: #E0F2FE;
  --white: #FFFFFF;
  --off-white: #F8FDFB;
  --slate: #1E293B;
  --slate-mid: #334155;
  --muted: #64748B;
  --muted-light: #94A3B8;
  --red: #EF4444;
  --red-soft: #FEE2E2;
  --amber: #F59E0B;
  --amber-soft: #FEF3C7;
  --green: #10B981;
  --green-soft: #D1FAE5;
  --purple: #8B5CF6;
  --purple-soft: #EDE9FE;
  --card-radius: 24px;
  --shadow: 0 4px 32px rgba(45,196,178,0.10);
  --shadow-lg: 0 8px 48px rgba(45,196,178,0.16);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Nunito', sans-serif;
  background: var(--off-white);
  color: var(--slate);
  overflow-x: hidden;
}
 
/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 40px;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid rgba(45,196,178,0.12);
}
.nav-logo { display: flex; align-items: center; gap: 10px; }
.nav-logo-icon {
  width: 40px; height: 40px; border-radius: 12px;
  background: linear-gradient(135deg, var(--teal), var(--cyan));
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
}
.nav-logo-text { font-size: 22px; font-weight: 800; color: var(--slate); }
.nav-logo-text span { color: var(--teal); }
.nav-links { display: flex; gap: 32px; }
.nav-links a { font-size: 15px; font-weight: 600; color: var(--muted); text-decoration: none; transition: color .2s; }
.nav-links a:hover { color: var(--teal); }
.nav-cta {
  padding: 10px 24px; border-radius: 50px;
  background: linear-gradient(135deg, var(--teal), var(--cyan));
  color: white; font-size: 15px; font-weight: 700; border: none; cursor: pointer;
  transition: transform .2s, box-shadow .2s;
}
.nav-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(45,196,178,0.4); }
 
/* SECTIONS */
section { padding: 80px 40px; }
.container { max-width: 1200px; margin: 0 auto; }
 
/* ===== HERO ===== */
.hero {
  min-height: 100vh; padding-top: 120px; padding-bottom: 80px;
  background: linear-gradient(155deg, #F0FDFC 0%, #E0F2FE 40%, #F8FDFB 100%);
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; top: -100px; right: -100px;
  width: 600px; height: 600px; border-radius: 50%;
  background: radial-gradient(circle, rgba(45,196,178,0.12), transparent 70%);
}
.hero::after {
  content: ''; position: absolute; bottom: -80px; left: -80px;
  width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(56,189,248,0.10), transparent 70%);
}
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--teal-light); color: var(--teal);
  padding: 8px 18px; border-radius: 50px; font-size: 13px; font-weight: 700;
  margin-bottom: 24px; border: 1px solid rgba(45,196,178,0.3);
}
.hero-badge::before { content: '●'; font-size: 8px; animation: blink 1.5s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
h1 {
  font-size: 56px; font-weight: 900; line-height: 1.1;
  color: var(--slate); margin-bottom: 24px;
}
h1 em { font-style: normal; color: var(--teal); }
.hero-sub { font-size: 19px; color: var(--muted); line-height: 1.7; margin-bottom: 40px; }
.hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
.btn-primary {
  padding: 16px 32px; border-radius: 50px;
  background: linear-gradient(135deg, var(--teal), var(--cyan));
  color: white; font-size: 16px; font-weight: 700; border: none; cursor: pointer;
  transition: transform .2s, box-shadow .2s; text-decoration: none; display: inline-block;
}
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(45,196,178,0.45); }
.btn-secondary {
  padding: 16px 32px; border-radius: 50px;
  background: white; color: var(--slate); font-size: 16px; font-weight: 700;
  border: 2px solid rgba(45,196,178,0.3); cursor: pointer; text-decoration: none;
  transition: all .2s; display: inline-block;
}
.btn-secondary:hover { border-color: var(--teal); color: var(--teal); }
.btn-emergency {
  padding: 16px 32px; border-radius: 50px;
  background: var(--red-soft); color: var(--red); font-size: 16px; font-weight: 700;
  border: 2px solid rgba(239,68,68,0.3); cursor: pointer; text-decoration: none;
  transition: all .2s; display: inline-block;
}
.btn-emergency:hover { background: var(--red); color: white; }
 
/* HERO CARD VISUAL */
.hero-visual { position: relative; }
.hero-card-main {
  background: white; border-radius: 28px; padding: 28px;
  box-shadow: var(--shadow-lg); border: 1px solid rgba(45,196,178,0.15);
}
.hero-card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--teal-light), var(--sky)); display: flex; align-items: center; justify-content: center; font-size: 22px; }
.hero-stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.hero-stat {
  background: var(--off-white); border-radius: 16px; padding: 14px;
  border: 1px solid rgba(45,196,178,0.12);
}
.hero-stat-label { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
.hero-stat-val { font-size: 26px; font-weight: 800; margin-top: 4px; }
.hero-stat-val.teal { color: var(--teal); }
.hero-stat-val.blue { color: var(--blue); }
.hero-stat-val.green { color: var(--green); }
.hero-stat-val.amber { color: var(--amber); }
.float-badge {
  position: absolute; background: white; border-radius: 16px; padding: 12px 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.10); display: flex; align-items: center; gap: 8px;
  font-size: 13px; font-weight: 700; border: 1px solid rgba(45,196,178,0.15);
}
.float-badge.top-right { top: -20px; right: -20px; }
.float-badge.bottom-left { bottom: 20px; left: -30px; }
 
/* SECTION TITLES */
.section-title { font-size: 42px; font-weight: 900; color: var(--slate); margin-bottom: 12px; }
.section-title span { color: var(--teal); }
.section-sub { font-size: 18px; color: var(--muted); margin-bottom: 48px; max-width: 560px; line-height: 1.6; }
 
/* FEATURES */
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.feature-card {
  background: white; border-radius: var(--card-radius); padding: 32px;
  border: 1px solid rgba(45,196,178,0.12); box-shadow: var(--shadow);
  transition: transform .25s, box-shadow .25s;
}
.feature-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
.feature-icon {
  width: 56px; height: 56px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; margin-bottom: 18px;
}
.feature-icon.teal { background: var(--teal-light); }
.feature-icon.blue { background: var(--blue-soft); }
.feature-icon.green { background: var(--green-soft); }
.feature-icon.amber { background: var(--amber-soft); }
.feature-icon.purple { background: var(--purple-soft); }
.feature-icon.red { background: var(--red-soft); }
.feature-card h3 { font-size: 20px; font-weight: 800; margin-bottom: 10px; }
.feature-card p { font-size: 15px; color: var(--muted); line-height: 1.7; }
 
/* ===== DASHBOARD ===== */
.dashboard-section { background: linear-gradient(160deg, #F0FDFC, #EFF6FF); }
.dashboard-wrap {
  background: var(--slate); border-radius: 32px; overflow: hidden;
  box-shadow: 0 16px 64px rgba(30,41,59,0.3); border: 1px solid rgba(255,255,255,0.1);
}
.dashboard-topbar {
  background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 16px 28px; display: flex; align-items: center; justify-content: space-between;
}
.dashboard-title { color: white; font-size: 16px; font-weight: 700; }
.status-pill { background: rgba(16,185,129,0.2); color: #6EE7B7; padding: 5px 14px; border-radius: 50px; font-size: 12px; font-weight: 700; }
.dashboard-grid { display: grid; grid-template-columns: 220px 1fr; gap: 0; }
.dashboard-sidebar {
  background: rgba(255,255,255,0.04); padding: 24px 16px;
  border-right: 1px solid rgba(255,255,255,0.07);
}
.sidebar-nav-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-radius: 14px; margin-bottom: 6px;
  font-size: 14px; color: rgba(255,255,255,0.6); font-weight: 600; cursor: pointer;
  transition: all .2s;
}
.sidebar-nav-item:hover, .sidebar-nav-item.active {
  background: rgba(45,196,178,0.15); color: var(--teal-mid);
}
.dashboard-main { padding: 24px; }
.dash-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
.dash-stat-card {
  background: rgba(255,255,255,0.07); border-radius: 18px; padding: 18px;
  border: 1px solid rgba(255,255,255,0.08);
}
.dash-stat-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.dash-stat-icon { font-size: 20px; }
.dash-stat-badge { font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 50px; }
.badge-up { background: rgba(16,185,129,0.2); color: #6EE7B7; }
.badge-warn { background: rgba(245,158,11,0.2); color: #FCD34D; }
.badge-alert { background: rgba(239,68,68,0.2); color: #FCA5A5; }
.dash-stat-val { font-size: 28px; font-weight: 800; color: white; }
.dash-stat-label { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; font-weight: 600; }
 
.dash-mid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 20px; }
.dash-panel {
  background: rgba(255,255,255,0.06); border-radius: 18px; padding: 18px;
  border: 1px solid rgba(255,255,255,0.08);
}
.dash-panel-title { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.6); margin-bottom: 14px; text-transform: uppercase; letter-spacing: .05em; }
 
/* Mini bar chart */
.mini-bars { display: flex; align-items: flex-end; gap: 5px; height: 60px; }
.mini-bar { flex: 1; border-radius: 4px 4px 0 0; background: rgba(45,196,178,0.3); transition: height .3s; }
.mini-bar.active { background: var(--teal-mid); }
 
/* Donut */
.donut-wrap { display: flex; align-items: center; gap: 16px; }
.donut { width: 70px; height: 70px; }
.donut circle { fill: none; stroke-width: 8; stroke-linecap: round; }
.donut-bg { stroke: rgba(255,255,255,0.08); }
.donut-fill { stroke: var(--teal-mid); stroke-dasharray: 188; stroke-dashoffset: 35; transform-origin: center; transform: rotate(-90deg); }
.donut-text { font-size: 11px; color: rgba(255,255,255,0.7); }
 
/* Medication schedule */
.med-list { display: flex; flex-direction: column; gap: 8px; }
.med-item { display: flex; align-items: center; gap: 10px; }
.med-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.med-name { font-size: 12px; color: rgba(255,255,255,0.8); font-weight: 600; flex: 1; }
.med-time { font-size: 11px; color: rgba(255,255,255,0.4); }
.med-check { font-size: 14px; }
 
/* AI Score */
.ai-score-ring { text-align: center; }
.ai-score-num { font-size: 42px; font-weight: 900; color: white; }
.ai-score-sub { font-size: 11px; color: rgba(255,255,255,0.5); }
.ai-score-bar { height: 6px; border-radius: 3px; background: rgba(255,255,255,0.1); margin-top: 10px; overflow: hidden; }
.ai-score-fill { height: 100%; width: 87%; border-radius: 3px; background: linear-gradient(90deg, var(--teal), var(--cyan)); }
 
/* ===== AI RISK ===== */
.risk-section { background: white; }
.risk-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
.risk-card {
  border-radius: var(--card-radius); padding: 28px;
  border: 1px solid rgba(45,196,178,0.12); box-shadow: var(--shadow);
}
.risk-card.low { background: linear-gradient(135deg, #F0FDFA, #ECFDF5); }
.risk-card.medium { background: linear-gradient(135deg, #FFFBEB, #FEF3C7); }
.risk-card.high { background: linear-gradient(135deg, #FFF5F5, #FEE2E2); }
.risk-card.info { background: linear-gradient(135deg, #F0F9FF, #E0F2FE); }
.risk-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.risk-title { font-size: 18px; font-weight: 800; }
.risk-badge { padding: 5px 14px; border-radius: 50px; font-size: 12px; font-weight: 700; }
.risk-badge.low { background: var(--green-soft); color: var(--green); }
.risk-badge.medium { background: var(--amber-soft); color: var(--amber); }
.risk-badge.high { background: var(--red-soft); color: var(--red); }
.risk-pct { font-size: 48px; font-weight: 900; margin-bottom: 8px; }
.risk-pct.green { color: var(--green); }
.risk-pct.amber { color: var(--amber); }
.risk-pct.red { color: var(--red); }
.risk-pct.blue { color: var(--blue); }
.risk-bar-track { height: 8px; border-radius: 4px; background: rgba(0,0,0,0.08); margin-bottom: 14px; }
.risk-bar-fill { height: 100%; border-radius: 4px; }
.insight-box {
  background: rgba(255,255,255,0.7); border-radius: 14px; padding: 14px;
  font-size: 14px; color: var(--slate-mid); line-height: 1.6; font-style: italic;
  border-left: 4px solid var(--teal);
}
 
/* ===== VOICE COMPANION ===== */
.voice-section { background: linear-gradient(160deg, #0F172A 0%, #1E293B 60%, #0F2A2A 100%); }
.voice-section .section-title { color: white; }
.voice-section .section-sub { color: rgba(255,255,255,0.6); }
.voice-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.voice-avatar-wrap { text-align: center; position: relative; }
.voice-rings {
  position: relative; width: 240px; height: 240px; margin: 0 auto 32px;
  display: flex; align-items: center; justify-content: center;
}
.voice-ring {
  position: absolute; border-radius: 50%; border: 2px solid rgba(45,196,178,0.2);
  animation: pulse-ring 2.5s ease-in-out infinite;
}
.voice-ring:nth-child(1) { width: 240px; height: 240px; animation-delay: 0s; }
.voice-ring:nth-child(2) { width: 190px; height: 190px; animation-delay: .4s; }
.voice-ring:nth-child(3) { width: 140px; height: 140px; animation-delay: .8s; }
@keyframes pulse-ring { 0%,100%{opacity:.3;transform:scale(1)} 50%{opacity:.7;transform:scale(1.04)} }
.voice-core {
  width: 110px; height: 110px; border-radius: 50%;
  background: linear-gradient(135deg, var(--teal), var(--cyan));
  display: flex; align-items: center; justify-content: center;
  font-size: 48px; box-shadow: 0 0 40px rgba(45,196,178,0.4);
  position: relative; z-index: 1;
}
.voice-wave { display: flex; align-items: center; gap: 4px; justify-content: center; margin-bottom: 24px; }
.voice-bar { width: 4px; border-radius: 2px; background: var(--teal-mid); animation: wave 1.2s ease-in-out infinite; }
.voice-bar:nth-child(1){height:12px;animation-delay:.0s}
.voice-bar:nth-child(2){height:24px;animation-delay:.1s}
.voice-bar:nth-child(3){height:36px;animation-delay:.2s}
.voice-bar:nth-child(4){height:48px;animation-delay:.3s}
.voice-bar:nth-child(5){height:36px;animation-delay:.4s}
.voice-bar:nth-child(6){height:24px;animation-delay:.5s}
.voice-bar:nth-child(7){height:12px;animation-delay:.6s}
@keyframes wave { 0%,100%{transform:scaleY(.5)} 50%{transform:scaleY(1)} }
.voice-btn {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--teal), var(--cyan));
  border: none; font-size: 32px; cursor: pointer; margin: 0 auto; display: block;
  box-shadow: 0 6px 32px rgba(45,196,178,0.5); transition: transform .2s;
}
.voice-btn:hover { transform: scale(1.08); }
 
.chat-bubbles { display: flex; flex-direction: column; gap: 16px; }
.bubble {
  padding: 16px 20px; border-radius: 20px; font-size: 16px; line-height: 1.6; max-width: 90%;
  font-weight: 600;
}
.bubble.ai {
  background: rgba(45,196,178,0.15); color: var(--teal-mid);
  border: 1px solid rgba(45,196,178,0.25); align-self: flex-start;
  border-bottom-left-radius: 4px;
}
.bubble.user {
  background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85);
  align-self: flex-end; border-bottom-right-radius: 4px;
}
.bubble-time { font-size: 11px; opacity: .5; display: block; margin-top: 4px; }
 
/* ===== EMERGENCY ===== */
.emergency-section { background: linear-gradient(160deg, #FFF5F5, #FFF0F0); }
.emergency-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 40px; align-items: start; }
.sos-btn-wrap { text-align: center; }
.sos-btn {
  width: 160px; height: 160px; border-radius: 50%;
  background: linear-gradient(135deg, #EF4444, #DC2626);
  border: none; font-size: 18px; font-weight: 900; color: white;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 6px; margin: 0 auto 24px;
  box-shadow: 0 8px 40px rgba(239,68,68,0.5);
  transition: transform .2s;
  animation: sos-pulse 3s ease-in-out infinite;
}
@keyframes sos-pulse { 0%,100%{box-shadow: 0 8px 40px rgba(239,68,68,0.5)} 50%{box-shadow: 0 8px 60px rgba(239,68,68,0.8)} }
.sos-btn:hover { transform: scale(1.06); }
.sos-label { font-size: 28px; font-weight: 900; }
.emergency-alerts { display: flex; flex-direction: column; gap: 14px; }
.alert-card {
  background: white; border-radius: 18px; padding: 20px;
  border: 1px solid rgba(239,68,68,0.15); display: flex; align-items: center; gap: 16px;
  box-shadow: 0 2px 16px rgba(239,68,68,0.08);
}
.alert-icon { font-size: 28px; flex-shrink: 0; }
.alert-title { font-size: 16px; font-weight: 800; color: var(--slate); }
.alert-desc { font-size: 14px; color: var(--muted); margin-top: 2px; }
.alert-badge { margin-left: auto; padding: 5px 12px; border-radius: 50px; font-size: 12px; font-weight: 700; white-space: nowrap; }
.alert-badge.active { background: var(--red-soft); color: var(--red); }
.alert-badge.monitoring { background: var(--green-soft); color: var(--green); }
.alert-badge.ready { background: var(--blue-soft); color: var(--blue); }
 
/* ===== SOCIAL ===== */
.social-section { background: linear-gradient(160deg, #F5F3FF, #EFF6FF); }
.clubs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
.club-card {
  background: white; border-radius: 20px; padding: 24px;
  border: 1px solid rgba(139,92,246,0.1); box-shadow: var(--shadow);
  transition: transform .25s, box-shadow .25s; cursor: pointer;
}
.club-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.club-emoji { font-size: 36px; margin-bottom: 12px; }
.club-name { font-size: 17px; font-weight: 800; color: var(--slate); margin-bottom: 6px; }
.club-members { font-size: 13px; color: var(--muted); }
.club-next { font-size: 12px; color: var(--purple); font-weight: 700; margin-top: 8px; }
.social-score {
  background: linear-gradient(135deg, var(--purple), #6366F1);
  border-radius: var(--card-radius); padding: 32px; color: white; text-align: center;
}
.social-score-num { font-size: 72px; font-weight: 900; }
.social-score-label { font-size: 18px; opacity: .8; }
 
/* ===== CAREGIVER ===== */
.caregiver-section { background: white; }
.caregiver-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
.caregiver-card {
  background: var(--off-white); border-radius: var(--card-radius); padding: 24px;
  border: 1px solid rgba(45,196,178,0.12);
}
.caregiver-card-title { font-size: 16px; font-weight: 800; color: var(--slate); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.health-trend { display: flex; flex-direction: column; gap: 10px; }
.trend-row { display: flex; align-items: center; gap: 10px; }
.trend-label { font-size: 13px; color: var(--muted); width: 100px; font-weight: 600; }
.trend-bar-wrap { flex: 1; height: 8px; background: rgba(45,196,178,0.12); border-radius: 4px; overflow: hidden; }
.trend-bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--teal), var(--cyan)); }
.trend-val { font-size: 13px; font-weight: 700; width: 40px; text-align: right; }
 
